{
  "name": "vanilla-bean",
  "version": "0.0.1-rc.9",
  "type": "module",
  "description": "Tiny framework with signals, hydration, and streaming SSR, built for Ant.",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "bin": {
    "vanilla-bean": "./src/build/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/build/vite/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "bin": {
      "vanilla-bean": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "import": "./dist/vite.js"
      }
    }
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "chalk": "^5.3.0",
    "elysia": "^1.4.29",
    "linkedom": "^0.18.12",
    "vite": "~8.0.16"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
