{
  "name": "vanilla-bean",
  "version": "0.0.3",
  "type": "module",
  "description": "Tiny framework with signals, hydration, and streaming SSR, built for Ant.",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1",
  "homepage": "https://vanilla.cafe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theMackabu/vanilla-bean.git"
  },
  "bin": {
    "vanilla-bean": "dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../../README.md README.md"
  },
  "publishConfig": {
    "tag": "next"
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "chalk": "^5.3.0",
    "elysia": "^1.4.29",
    "linkedom": "^0.18.12",
    "vite": "~8.0.16"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
